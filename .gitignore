# =============================================================================
# Quilgo Automation Suite — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials & secrets — never commit these
# -----------------------------------------------------------------------------
.env
gui_config.ini

# -----------------------------------------------------------------------------
# Runtime data — generated on each run, not source code
# -----------------------------------------------------------------------------
Quilgo/
downloads/
selected_quizzes.json
Manatal_test_api/
check_output/

# -----------------------------------------------------------------------------
# Playwright artefacts
# -----------------------------------------------------------------------------
test-results/
playwright-report/
playwright_downloader/

# -----------------------------------------------------------------------------
# PyInstaller build output
# -----------------------------------------------------------------------------
build/
dist/
*.spec

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
.env/

# Distribution / packaging
*.egg-info/
*.egg
.eggs/
*.whl
MANIFEST

# Coverage / testing
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/

# Type checking
.mypy_cache/
.dmypy.json
.pytype/

# Jupyter
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
package-lock.json

# -----------------------------------------------------------------------------
# Editor & OS noise
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Editor temporary save files (VS Code / Claude Code atomic-write leftovers)
*.tmp.*
